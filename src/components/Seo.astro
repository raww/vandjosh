---
// Every head tag that search engines and share cards read, derived from
// src/data/site.js + the calling page's props (which come from projects.js).
// Content and SEO can't drift apart: there is nothing to hand-sync.
import { SITE } from '../data/site.js';
import { withBase } from '../lib/paths.js';

const { title = SITE.title, description = SITE.description, type = 'website', jsonLd = null } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(withBase('og/card.png'), Astro.site);
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical.href} />
<link rel="icon" href={withBase('favicon.svg')} type="image/svg+xml" />
<link rel="sitemap" href={withBase('sitemap-index.xml')} />
<meta name="theme-color" content="#0B0B0C" />
<meta name="generator" content={Astro.generator} />

<meta property="og:site_name" content={SITE.name} />
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical.href} />
<meta property="og:image" content={ogImage.href} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={SITE.ogImageAlt} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage.href} />

{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
