---
// One project fills one frame: centred title + description, then an
// asymmetric collage whose arrangement depends on how much media and
// info (stats / notes / press) the project has.
//
// Media entries ending in .mp4 render as muted looping film moments.
// A project with `video` (self-hosted mp4) or `youtube` (video id) gets a
// real play affordance on its feature tile — clicking swaps in the player
// (wired up in src/scripts/app.js). An optional `quote` renders as the
// white serif press-quote band across the feature tile.
import { PRESS } from '../data/projects.js';
import { withBase } from '../lib/paths.js';

const { project } = Astro.props;

// media entries are strings or { src, pos } (pos anchors the crop, e.g.
// 'top' keeps a press clipping's headline in view)
const media = [project.hero, ...(project.images || [])]
  .filter(Boolean)
  .map((m) => (typeof m === 'string' ? { src: m } : m));
const n = media.length;
const film = project.disciplines.includes('Film');
const hasInfo =
  (project.stats && project.stats.length > 0) ||
  (project.press && project.press.length > 0) ||
  (project.notes && project.notes.length > 0);

// a press logo links out to the actual coverage when we have the URL
const press = (project.press || [])
  .filter((k) => PRESS[k])
  .map((k) => ({ file: PRESS[k], url: (project.pressLinks || {})[k] }));
const playable = Boolean(project.video || project.youtube);
const showPlay = film || playable;

// choose a collage arrangement: grid template + which slots render
const [feat, b, c] = media;
let grid;
let slots; // ordered list of { kind: 'tile' | 'info' | 'cover', src?, area, feature? }

if (n === 0) {
  if (hasInfo) {
    grid = { cols: '1.25fr 1fr', rows: '1fr', areas: `"feat info"` };
    slots = [
      { kind: 'cover', area: 'feat' },
      { kind: 'info', area: 'info' },
    ];
  } else {
    grid = { cols: '1fr', rows: '1fr', areas: `"feat"` };
    slots = [{ kind: 'cover', area: 'feat' }];
  }
} else if (n >= 4 && !hasInfo) {
  // uniform gallery (the deck's 3×2 LTA grid): two columns, row per pair
  const rows = Math.ceil(n / 2);
  const areas = Array.from({ length: rows }, (_, r) => `"m${r * 2} m${Math.min(r * 2 + 1, n - 1)}"`).join(' ');
  grid = { cols: '1fr 1fr', rows: `repeat(${rows}, 1fr)`, areas };
  slots = media.map((src, i) => ({ kind: 'tile', src, area: `m${i}`, feature: i === 0 }));
} else if (n >= 3 && hasInfo) {
  grid = { cols: '1.35fr 1fr', rows: '1fr 1fr', areas: `"feat side1" "info side2"` };
  slots = [
    { kind: 'tile', src: feat, area: 'feat', feature: true },
    { kind: 'tile', src: b, area: 'side1' },
    { kind: 'info', area: 'info' },
    { kind: 'tile', src: c, area: 'side2' },
  ];
} else if (n === 2 && hasInfo) {
  grid = { cols: '1.35fr 1fr', rows: '1fr 1fr', areas: `"feat side1" "info side1"` };
  slots = [
    { kind: 'tile', src: feat, area: 'feat', feature: true },
    { kind: 'tile', src: b, area: 'side1' },
    { kind: 'info', area: 'info' },
  ];
} else if (n === 1 && hasInfo && playable) {
  // film-led project (the deck's Nescafé / Queen of Small pages):
  // wide player on top, stats + press centred beneath
  grid = { cols: '1fr', rows: '1.7fr auto', areas: `"feat" "info"` };
  slots = [
    { kind: 'tile', src: feat, area: 'feat', feature: true },
    { kind: 'info', area: 'info', below: true },
  ];
} else if (n === 1 && hasInfo) {
  grid = { cols: '1fr 1.4fr', rows: '1fr', areas: `"info feat"` };
  slots = [
    { kind: 'info', area: 'info' },
    { kind: 'tile', src: feat, area: 'feat', feature: true },
  ];
} else if (n >= 3) {
  grid = { cols: '1.4fr 1fr', rows: '1fr 1fr', areas: `"feat side1" "feat side2"` };
  slots = [
    { kind: 'tile', src: feat, area: 'feat', feature: true },
    { kind: 'tile', src: b, area: 'side1' },
    { kind: 'tile', src: c, area: 'side2' },
  ];
} else if (n === 2) {
  grid = { cols: '1.2fr 1fr', rows: '1fr', areas: `"feat side1"` };
  slots = [
    { kind: 'tile', src: feat, area: 'feat', feature: true },
    { kind: 'tile', src: b, area: 'side1' },
  ];
} else {
  grid = { cols: '1fr', rows: '1fr', areas: `"feat"` };
  slots = [{ kind: 'tile', src: feat, area: 'feat', feature: true }];
}

const gridStyle = `grid-template-columns:${grid.cols};grid-template-rows:${grid.rows};grid-template-areas:${grid.areas};`;
const isLoop = (m) => m.src.endsWith('.mp4');
---

<section class="vj-frame">
  <header class="vj-frame-header">
    <h1>{project.client} &ndash; {project.title}</h1>
    {project.description && <p class="vj-frame-desc">{project.description}</p>}
  </header>

  <div class="vj-collage" style={gridStyle}>
    {
      slots.map((slot) => {
        if (slot.kind === 'tile') {
          const feature = slot.feature;
          const playsHere = feature && playable;
          const Tile = playsHere ? 'button' : 'div';
          return (
            <Tile
              class:list={['vj-tile', { 'vj-tile-playable': playsHere }]}
              style={`grid-area:${slot.area}`}
              data-video={playsHere && project.video ? withBase(project.video) : undefined}
              data-youtube={playsHere ? project.youtube : undefined}
              aria-label={playsHere ? `Play the ${project.title} film` : undefined}
            >
              {isLoop(slot.src) ? (
                <video class="vj-tile-media" src={withBase(slot.src.src)} autoplay muted loop playsinline preload="metadata" />
              ) : (
                <img
                  class:list={['vj-tile-media', { 'vj-tile-media-card': slot.src.fit === 'contain' }]}
                  src={withBase(slot.src.src)}
                  alt=""
                  style={slot.src.pos ? `object-position:${slot.src.pos}` : undefined}
                  loading={feature ? 'eager' : 'lazy'}
                  fetchpriority={feature ? 'high' : undefined}
                />
              )}
              {feature &&
                (project.stickers || []).map((s) => (
                  <img class={`vj-sticker vj-sticker-${s.side}`} src={withBase(s.src)} alt="" />
                ))}
              {feature && showPlay && (
                <div class="vj-play">
                  <div class="vj-play-ring">
                    <svg width="26" height="30" viewBox="0 0 26 30" aria-hidden="true">
                      <path d="M2 2 L24 15 L2 28 Z" fill="#fff" />
                    </svg>
                  </div>
                </div>
              )}
              {feature && project.quote && (
                <figure class="vj-quote">
                  <blockquote>&lsquo;{project.quote.text}&rsquo;</blockquote>
                  <figcaption>&mdash; {project.quote.source}</figcaption>
                </figure>
              )}
            </Tile>
          );
        }
        if (slot.kind === 'cover') {
          return (
            <div class="vj-textcover" style={`grid-area:${slot.area}`}>
              <span class="vj-textcover-title">{project.title}</span>
              {showPlay && (
                <div class="vj-play-ring">
                  <svg width="22" height="26" viewBox="0 0 26 30" aria-hidden="true">
                    <path d="M2 2 L24 15 L2 28 Z" fill="#fff" />
                  </svg>
                </div>
              )}
            </div>
          );
        }
        return (
          <div class:list={['vj-info', { 'vj-info-below': slot.below }]} style={`grid-area:${slot.area}`}>
            {project.stats && project.stats.length > 0 && (
              <div class="vj-stats">
                {project.stats.map((s) => (
                  <div class="vj-stat">
                    <span class="vj-stat-figure">{s.figure}</span>
                    <span class="vj-stat-label">{s.label}</span>
                  </div>
                ))}
              </div>
            )}
            {project.notes && project.notes.length > 0 && (
              <div class="vj-notes">
                {project.notes.map((note) => (
                  <span>{note}</span>
                ))}
              </div>
            )}
            {press.length > 0 && (
              <div class="vj-press-grid">
                {press.map(({ file, url }) =>
                  url ? (
                    <a href={url} target="_blank" rel="noopener" class="vj-press-link" aria-label="Read the coverage">
                      <img src={withBase(`assets/press/${file}`)} alt="" loading="lazy" />
                    </a>
                  ) : (
                    <img src={withBase(`assets/press/${file}`)} alt="" loading="lazy" />
                  )
                )}
              </div>
            )}
          </div>
        );
      })
    }
  </div>
</section>
